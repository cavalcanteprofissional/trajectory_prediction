# CONFIGURAÇÕES DO PROJETO
# Copie este arquivo para .env.local e configure se necessário
# NÃO commite o .env.local no Git!

# Seed para reprodutibilidade (padrão: 42)
SEED=

# Diretório dos dados (padrão: data)
DATA_DIR=

# Kaggle API (obrigatório para download automático)
# Get credentials at: https://www.kaggle.com/account
KAGGLE_USERNAME=
KAGGLE_KEY=